# Database & output paths
RL_DB_PATH=rocketleague.db
RL_EXPORT_DIR=exports
RL_LOG_DIR=logs

# Source endpoints (replace with your actual targets)
RL_BLAST_BASE_URL=https://api.example.com
RL_BLAST_API_BASE_URL=https://api.example.com/v1
RL_LIQUIPEDIA_BASE_URL=https://wiki.example.com
RL_DREKT_CSV_URLS=https://example.com/sheet1.csv,https://example.com/sheet2.csv

# Rate limits & concurrency
RL_HTTP_TIMEOUT_SECONDS=30
RL_BLAST_RATE_LIMIT_SECONDS=0.75
RL_LIQUIPEDIA_RATE_LIMIT_SECONDS=2.0
RL_SPREADSHEET_RATE_LIMIT_SECONDS=0.25
RL_MAX_CONCURRENCY=6

# Browser automation fingerprint (set 0 to disable)
RL_BLAST_FINGERPRINT_SEED=0
RL_BLAST_PROBE_DEEP_STATS=false
RL_BLAST_MAX_DISCOVERED_TOURNAMENTS=16

# Request identity
RL_USER_AGENT="DataBot/1.0 (+https://github.com/yourusername/data-scrapers)"

# Discovery seeds (comma-separated)
RL_BLAST_TOURNAMENT_SLUGS=event-1,event-2,major-2026
RL_LIQUIPEDIA_SEED_PAGES=Season/2026,Season/2025,Transfers
RL_RLCS_REGIONS=NA,EU,SAM,OCE,MENA,APAC,SSA
